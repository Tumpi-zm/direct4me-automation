{
  "name": "direct4me-automation",
  "version": "1.0.0",
  "description": "Playwright test automation framework for service.direct4.me",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:auth": "playwright test tests/auth/",
    "test:ops": "playwright test tests/ops/",
    "test:maintainer": "playwright test tests/maintainer/",
    "codegen": "playwright codegen https://service.direct4.me"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
